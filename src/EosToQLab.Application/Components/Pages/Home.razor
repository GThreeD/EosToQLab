@page "/"

@inject IEosCueImporterFactory ImporterFactory
@inject IQLabService QLabService
@inject IQLabPasscodeStore PasscodeStore
@inject IJSRuntime JS

<PageTitle>EosToQLab</PageTitle>

<section class="hero">
    <div>
        <div class="eyebrow">Import workflow</div>
        <h1>Build a protected QLab cue list from EOS</h1>
        <p>Choose an EOS CSV, ESF2, or ESF3D file, review and edit the parsed cues, and import them into a workspace that is
            already open in QLab 5.</p>
    </div>
    <div class="status-pill @(_busy ? "working" : "ready")">
        @(_busy ? "Working…" : "Ready")
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <div class="alert error">
        <strong>@_errorCode</strong>
        <span>@_errorMessage</span>
    </div>
}
@if (!string.IsNullOrWhiteSpace(_successMessage))
{
    <div class="alert success">@_successMessage</div>
}

<div class="workflow-grid">
    <section class="card source-card">
        <div class="step-heading">
            <span class="step-number">1</span>
            <div>
                <h2>EOS source</h2>
                <p>CSV and EOS show archives use separate import strategies behind the same interface.</p>
            </div>
        </div>

        <label class="drop-zone @(_busy ? "disabled" : string.Empty)">
            <InputFile OnChange="LoadSourceAsync" disabled="@_busy"/>
            <span class="drop-icon">⇩</span>
            <strong>Drop a file here or click to choose</strong>
            <span>Accepted: .csv, .esf2, .esf3d</span>
        </label>

        @if (_source is not null)
        {
            <div class="source-summary">
                <div>
                    <span class="label">Source</span>
                    <strong>@_source.SourceDescription</strong>
                </div>
                <div>
                    <span class="label">Strategy</span>
                    <strong>@_source.SourceKind</strong>
                </div>
                <div>
                    <span class="label">Selected</span>
                    <strong>@SelectedCueCount / @_previewRows.Count</strong>
                </div>
            </div>
        }
    </section>

    <section class="card target-card">
        <div class="step-heading">
            <span class="step-number">2</span>
            <div>
                <h2>Open QLab workspace</h2>
                <p>The app never creates or opens a QLab document.</p>
            </div>
        </div>

        <button class="secondary" @onclick="RefreshWorkspacesAsync" disabled="@_busy">Refresh open workspaces</button>

        <label class="field">
            <span>Workspace</span>
            <select value="@_selectedWorkspaceId" @onchange="WorkspaceChangedAsync"
                    disabled="@(_busy || _workspaces.Count == 0)">
                <option value="">Select an open workspace</option>
                @foreach (var workspace in _workspaces)
                {
                    <option value="@workspace.Id">@workspace.Name</option>
                }
            </select>
        </label>

        <label class="field">
            <span>OSC passcode (optional)</span>
            <input type="password"
                   value="@_passcode"
                   @onchange="PasscodeChangedAsync"
                   disabled="@(_busy || string.IsNullOrWhiteSpace(_selectedWorkspaceId))"
                   autocomplete="off"/>
            <small>The passcode is kept only in memory for this app session and expires after 24 hours. It is not
                written to disk.</small>
        </label>
    </section>
</div>

<section class="card options-card">
    <div class="step-heading">
        <span class="step-number">3</span>
        <div>
            <h2>Import options</h2>
            <p>A temporary cue list is populated first. Existing lists remain untouched unless replacement is explicitly
                confirmed.</p>
        </div>
    </div>

    <div class="form-grid">
        <label class="field">
            <span>New cue list name</span>
            <input @bind="CueListName" disabled="@_busy"/>
        </label>
        <div class="field">
            <span>QLab network patch</span>
            <select @bind="_selectedNetworkPatchId"
                    disabled="@(_busy || string.IsNullOrWhiteSpace(_selectedWorkspaceId) || _networkPatches.Count == 0)">
                <option value="">Select a network patch</option>
                @foreach (var patch in _networkPatches)
                {
                    <option value="@patch.Id">@PatchDisplayName(patch)</option>
                }
            </select>
            <button type="button"
                    class="text-button"
                    @onclick="RefreshNetworkPatchesAsync"
                    disabled="@(_busy || string.IsNullOrWhiteSpace(_selectedWorkspaceId))">
                Refresh patch list
            </button>
        </div>
        <label class="field">
            <span>Scene text</span>
            <select @bind="_sceneMode" disabled="@_busy">
                <option value="@SceneTextImportMode.Ignore">Ignore</option>
                <option value="@SceneTextImportMode.MemoCue">Create memo cues</option>
            </select>
            <small>Memo cues remain unnumbered. Network cues receive exactly the EOS cue number when that number is
                available in QLab.</small>
        </label>
        <label class="field">
            <span>Cues triggered by Follow/Hang</span>
            <select @bind="_followedCueMode" disabled="@_busy">
                <option value="@FollowedCueImportMode.Exclude">Do not import</option>
                <option value="@FollowedCueImportMode.ImportDisarmed">Import disarmed</option>
            </select>
            <small>A complete chain is detected per EOS list. For example, 83.1 → 83.2 → 83.3 → 84 marks 83.2 through 84
                as automatically triggered.</small>
        </label>
    </div>

    <div class="checks">
        <label><input type="checkbox" @bind="_saveWorkspace" disabled="@_busy"/> Save the QLab workspace after a
            successful import</label>
    </div>

    @if (_conflictDetected)
    {
        <div class="conflict-box">
            <strong>A cue list named “@_cueListName” already exists.</strong>
            <p>Replacement deletes only that matching list after the new temporary list has been built successfully.
                Network cue numbers are assigned afterwards, so they can reuse the EOS numbers released by the replaced
                list; numbers still used elsewhere remain blank.</p>
            <label>
                <input type="checkbox" @bind="_replacementConsent" disabled="@_busy"/>
                I explicitly approve replacing the existing cue list.
            </label>
        </div>
    }

    <button class="primary" @onclick="ImportToQLabAsync" disabled="@(!CanImport)">
        Import @SelectedCueCount selected cue@(SelectedCueCount == 1 ? string.Empty : "s") into QLab
    </button>
</section>

@if (_source is not null)
{
    <section class="card preview-card">
        <div class="preview-header">
            <div>
                <h2>Cue preview</h2>
                <p>Edit label, notes, and scene text before importing. Deselected rows remain part of Follow/Hang
                    analysis but are not created in QLab.</p>
            </div>
            <div class="selection-toolbar">
                <label class="selection-master">
                    <input @ref="_selectAllCheckbox"
                           type="checkbox"
                           checked="@AllCuesSelected"
                           @onchange="ToggleAllCues"
                           disabled="@(_busy || _previewRows.Count == 0)"
                           aria-checked="@SelectionAriaState"/>
                    <span>@SelectedCueCount / @_previewRows.Count selected</span>
                </label>
                <button type="button" class="text-button" @onclick="@(() => SetAllCues(true))"
                        disabled="@(_busy || AllCuesSelected)">Select all
                </button>
                <button type="button" class="text-button" @onclick="@(() => SetAllCues(false))"
                        disabled="@(_busy || SelectedCueCount == 0)">Deselect all
                </button>
            </div>
        </div>

        @if (_source.Diagnostics.Count > 0)
        {
            <div class="diagnostics">
                @foreach (var diagnostic in _source.Diagnostics)
                {
                    <div class="diagnostic">
                        <code>@diagnostic.Code</code>
                        <span>@diagnostic.Message</span>
                    </div>
                }
            </div>
        }

        <div class="table-wrap preview-table-wrap">
            <table class="preview-table">
                <thead>
                <tr>
                    <th class="selection-column">Import</th>
                    <th>#</th>
                    <th>EOS cue</th>
                    <th>Label / QLab network name</th>
                    <th>Notes / QLab network notes</th>
                    <th>Scene / QLab memo name</th>
                    <th>Follow/Hang</th>
                </tr>
                </thead>
                <tbody>
                @foreach (var row in _previewRows)
                {
                    <tr class="@(row.IsSelected ? string.Empty : "preview-row-excluded")">
                        <td class="selection-column">
                            <input type="checkbox" @bind="row.IsSelected" disabled="@_busy"
                                   aria-label="Import cue @row.DisplayCueNumber"/>
                        </td>
                        <td>@(row.SourceOrder + 1)</td>
                        <td><strong>@row.DisplayCueNumber</strong></td>
                        <td><input class="preview-input" @bind="row.Label" disabled="@_busy"
                                   aria-label="Label for cue @row.DisplayCueNumber"/></td>
                        <td><input class="preview-input" @bind="row.Notes" disabled="@_busy"
                                   aria-label="Notes for cue @row.DisplayCueNumber"/></td>
                        <td><input class="preview-input" @bind="row.Scene" disabled="@_busy"
                                   aria-label="Scene for cue @row.DisplayCueNumber"/></td>
                        <td>@(row.Follow ?? "—")</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </section>
}

@code {
    private const long MaximumSourceSize = 1024L * 1024L * 1024L;
    private EosImportResult? _source;
    private List<CuePreviewRow> _previewRows = [];
    private IReadOnlyList<QLabWorkspace> _workspaces = [];
    private IReadOnlyList<QLabNetworkPatch> _networkPatches = [];
    private ElementReference _selectAllCheckbox;
    private string _selectedWorkspaceId = string.Empty;
    private string _selectedNetworkPatchId = string.Empty;
    private string _passcode = string.Empty;
    private string _cueListName = $"EOS Import {DateTime.Now:yyyy-MM-dd HHmm}";
    private SceneTextImportMode _sceneMode = SceneTextImportMode.MemoCue;
    private FollowedCueImportMode _followedCueMode = FollowedCueImportMode.Exclude;
    private bool _saveWorkspace = true;
    private bool _conflictDetected;
    private bool _replacementConsent;
    private bool _busy;
    private string? _errorCode;
    private string? _errorMessage;
    private string? _successMessage;

    private string CueListName
    {
        get => _cueListName;
        set
        {
            if (string.Equals(_cueListName, value, StringComparison.Ordinal))
            {
                return;
            }

            _cueListName = value;
            ResetConflictState();
        }
    }

    private int SelectedCueCount => _previewRows.Count(row => row.IsSelected);
    private bool AllCuesSelected => _previewRows.Count > 0 && SelectedCueCount == _previewRows.Count;
    private bool SelectionIsIndeterminate => SelectedCueCount > 0 && !AllCuesSelected;
    private string SelectionAriaState => SelectionIsIndeterminate ? "mixed" : AllCuesSelected ? "true" : "false";

    private bool CanImport => !_busy
                              && _source is not null
                              && SelectedCueCount > 0
                              && !string.IsNullOrWhiteSpace(_selectedWorkspaceId)
                              && !string.IsNullOrWhiteSpace(_cueListName)
                              && !string.IsNullOrWhiteSpace(_selectedNetworkPatchId)
                              && (!_conflictDetected || _replacementConsent);

    protected override async Task OnInitializedAsync()
    {
        await RefreshWorkspacesAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_source is null)
        {
            return;
        }

        try
        {
            await JS.InvokeVoidAsync("eosToQLab.setIndeterminate", _selectAllCheckbox, SelectionIsIndeterminate);
        }
        catch (JSException)
        {
            // The next render will retry if the WebView is still initializing.
        }
    }

    private async Task LoadSourceAsync(InputFileChangeEventArgs eventArgs)
    {
        await RunGuardedAsync(async () =>
        {
            var file = eventArgs.File;
            await using var stream = file.OpenReadStream(MaximumSourceSize);
            await LoadSourceContentAsync(file.Name, stream, file.Size);
        });
    }

    private async Task LoadSourceContentAsync(string fileName, Stream source, long? sourceSize)
    {
        _source = null;
        _previewRows = [];
        _successMessage = null;
        _conflictDetected = false;
        _replacementConsent = false;

        if (sourceSize is > MaximumSourceSize)
        {
            throw new InvalidOperationException($"The selected source exceeds the {MaximumSourceSize / 1024 / 1024} MB limit.");
        }

        var initialCapacity = sourceSize is > 0 and <= int.MaxValue
            ? (int)sourceSize.Value
            : 0;
        using var content = new MemoryStream(initialCapacity);
        await source.CopyToAsync(content);
        if (content.Length > MaximumSourceSize)
        {
            throw new InvalidOperationException($"The selected source exceeds the {MaximumSourceSize / 1024 / 1024} MB limit.");
        }

        content.Position = 0;
        var importer = ImporterFactory.CreateFor(fileName);
        _source = await importer.ImportAsync(new EosImportRequest(fileName, content));
        _previewRows = _source.Cues.Select(CuePreviewRow.FromCue).ToList();
    }

    private async Task RefreshWorkspacesAsync()
    {
        await RunGuardedAsync(async () =>
        {
            _workspaces = await QLabService.GetOpenWorkspacesAsync();
            var nextWorkspaceId = _workspaces.Count == 1
                ? _workspaces[0].Id
                : _workspaces.Any(workspace => workspace.Id == _selectedWorkspaceId)
                    ? _selectedWorkspaceId
                    : string.Empty;

            if (!string.Equals(nextWorkspaceId, _selectedWorkspaceId, StringComparison.Ordinal))
            {
                await SelectWorkspaceCoreAsync(nextWorkspaceId);
            }
            else if (!string.IsNullOrWhiteSpace(nextWorkspaceId))
            {
                await LoadNetworkPatchesCoreAsync();
            }
        });
    }

    private async Task WorkspaceChangedAsync(ChangeEventArgs eventArgs)
    {
        var workspaceId = eventArgs.Value?.ToString() ?? string.Empty;
        await RunGuardedAsync(() => SelectWorkspaceCoreAsync(workspaceId));
    }

    private async Task SelectWorkspaceCoreAsync(string workspaceId)
    {
        _selectedWorkspaceId = workspaceId;
        _networkPatches = [];
        _selectedNetworkPatchId = string.Empty;
        _passcode = string.Empty;
        ResetConflictState();

        if (string.IsNullOrWhiteSpace(workspaceId))
        {
            return;
        }

        _passcode = await PasscodeStore.GetAsync(workspaceId) ?? string.Empty;
        await LoadNetworkPatchesCoreAsync();
    }

    private async Task PasscodeChangedAsync(ChangeEventArgs eventArgs)
    {
        _passcode = eventArgs.Value?.ToString() ?? string.Empty;
        if (string.IsNullOrWhiteSpace(_selectedWorkspaceId))
        {
            return;
        }

        await RunGuardedAsync(async () =>
        {
            await LoadNetworkPatchesCoreAsync();
            await PasscodeStore.SetAsync(_selectedWorkspaceId, NullIfWhiteSpace(_passcode));
        });
    }

    private Task RefreshNetworkPatchesAsync()
    {
        return RunGuardedAsync(LoadNetworkPatchesCoreAsync);
    }

    private async Task LoadNetworkPatchesCoreAsync()
    {
        if (string.IsNullOrWhiteSpace(_selectedWorkspaceId))
        {
            _networkPatches = [];
            _selectedNetworkPatchId = string.Empty;
            return;
        }

        var previousSelection = _selectedNetworkPatchId;
        _networkPatches = (await QLabService.GetNetworkPatchesAsync(
                _selectedWorkspaceId,
                NullIfWhiteSpace(_passcode)))
            .OrderBy(patch => patch.Name, StringComparer.OrdinalIgnoreCase)
            .ToArray();

        _selectedNetworkPatchId = _networkPatches.Any(patch =>
            string.Equals(patch.Id, previousSelection, StringComparison.OrdinalIgnoreCase))
            ? previousSelection
            : _networkPatches.Count == 1
                ? _networkPatches[0].Id
                : string.Empty;
    }

    private async Task ImportToQLabAsync()
    {
        if (_source is null || !CanImport)
        {
            return;
        }

        await RunGuardedAsync(async () =>
        {
            var selectedPatch = _networkPatches.FirstOrDefault(patch =>
                string.Equals(patch.Id, _selectedNetworkPatchId, StringComparison.OrdinalIgnoreCase));
            if (selectedPatch is null)
            {
                throw new InvalidOperationException("Select a QLab network patch before importing.");
            }

            await PasscodeStore.SetAsync(_selectedWorkspaceId, NullIfWhiteSpace(_passcode));

            var cueLists = await QLabService.GetCueListsAsync(
                _selectedWorkspaceId,
                NullIfWhiteSpace(_passcode));
            var hasConflict = cueLists.Any(list =>
                string.Equals(list.Name, _cueListName.Trim(), StringComparison.OrdinalIgnoreCase));

            if (hasConflict && !_replacementConsent)
            {
                _conflictDetected = true;
                _errorCode = "QLAB_CUE_LIST_CONFLICT";
                _errorMessage = "Explicit replacement consent is required before the existing cue list can be replaced.";
                return;
            }

            var editedCues = _previewRows.Select(row => row.ToCue()).ToArray();
            var result = await QLabService.ImportAsync(
                editedCues,
                new QLabImportOptions
                {
                    WorkspaceId = _selectedWorkspaceId,
                    Passcode = NullIfWhiteSpace(_passcode),
                    CueListName = _cueListName.Trim(),
                    NetworkPatchId = selectedPatch.Id,
                    NetworkPatchName = selectedPatch.Name,
                    SceneTextMode = _sceneMode,
                    FollowedCueMode = _followedCueMode,
                    ConflictPolicy = hasConflict
                        ? CueListConflictPolicy.ReplaceWithExplicitConsent
                        : CueListConflictPolicy.Fail,
                    ExplicitReplacementConsent = hasConflict && _replacementConsent,
                    SaveWorkspaceAfterImport = _saveWorkspace
                });

            _conflictDetected = false;
            _replacementConsent = false;
            _successMessage = $"Imported {result.NetworkCueCount} network cues and {result.MemoCueCount} memo cues into '{_cueListName}'.";
        });
    }

    private void ToggleAllCues(ChangeEventArgs eventArgs)
    {
        SetAllCues(eventArgs.Value is true || string.Equals(eventArgs.Value?.ToString(), "true", StringComparison.OrdinalIgnoreCase));
    }

    private void SetAllCues(bool selected)
    {
        foreach (var row in _previewRows)
        {
            row.IsSelected = selected;
        }
    }

    private async Task RunGuardedAsync(Func<Task> operation)
    {
        _busy = true;
        _errorCode = null;
        _errorMessage = null;
        try
        {
            await operation();
        }
        catch (EosToQLabException exception)
        {
            _errorCode = exception.Code;
            _errorMessage = exception.Message;
            if (exception is QLabCueListConflictException)
            {
                _conflictDetected = true;
            }
        }
        catch (Exception exception)
        {
            var wrapped = new UnexpectedApplicationException(exception);
            _errorCode = wrapped.Code;
            _errorMessage = wrapped.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private void ResetConflictState()
    {
        _conflictDetected = false;
        _replacementConsent = false;
    }

    private static string PatchDisplayName(QLabNetworkPatch patch)
    {
        return string.IsNullOrWhiteSpace(patch.Type)
            ? patch.Name
            : $"{patch.Name} ({patch.Type})";
    }

    private static string? NullIfWhiteSpace(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    }

}
